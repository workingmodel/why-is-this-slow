{
  "name": "wm-why-is-this-slow",
  "version": "0.1.0",
  "description": "Zero-config CLI that profiles a Node.js app and outputs a plain-English bottleneck report.",
  "license": "MIT",
  "author": "Working Model",
  "bin": {
    "wm-why-is-this-slow": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "execa": "^9.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "profiler",
    "performance",
    "nodejs",
    "cli",
    "bottleneck"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/workingmodel/wm-why-is-this-slow.git"
  }
}
